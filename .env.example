# ── Obligatorias ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
MONGO_URL=mongodb+srv://USER:PASS@HOST/?appName=carpinteria

# Secreto para firmar las sesiones de login. Poné algo largo y aleatorio.
AUTH_SESSION_SECRET=change-this-long-random-secret

# Credenciales de Google (catálogo Activa + herrajes): una de las dos.
# - Local: GOOGLE_SERVICE_ACCOUNT_FILE apunta al JSON.
# - Producción (Railway / Docker): GOOGLE_SERVICE_ACCOUNT_JSON.
#   RECOMENDADO: pegar el JSON codificado en base64 (no tiene caracteres que
#   los paneles de variables rompan). Generarlo con:
#     base64 -i secrets/google/google-service.json   (Mac/Linux)
#   También acepta el JSON crudo en una línea, pero pegarlo así suele cortarse
#   o romper los `\n` del private_key. Si las dos están seteadas, gana JSON.
GOOGLE_SERVICE_ACCOUNT_FILE=secrets/google/google-service.json
# GOOGLE_SERVICE_ACCOUNT_JSON=ewogICJ0eXBlIjogInNlcnZpY2VfYWNjb3VudCIsCiAg...

# ── Credenciales de bootstrap ────────────────────────────────────────────────
# Login de emergencia ANTES de que existan usuarios en Mongo. Si NO las seteás,
# el código cae a los valores hardcodeados casa2026 / pirone2026 (inseguro en
# producción). En Railway poné passwords fuertes acá.
CASA_AUTH_USER=casa
CASA_AUTH_PASSWORD=change-me
PIRONE_AUTH_USER=pirone
PIRONE_AUTH_PASSWORD=change-me

# ── Email para reset de contraseña (opcional) ────────────────────────────────
# Si no configurás SMTP, el reset por mail simplemente no se envía.
RESET_EMAIL_TO=lacasadelcarpinterosa@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

# ── Overrides opcionales ─────────────────────────────────────────────────────
# Todas estas tienen default en el código (carpinteria/settings.py y
# lista_precios_sheets.py); solo definilas si querés cambiar el valor.
# MONGO_DB=carpinteria
# PRICES_SHEET_ID=1mcp2xyADcYN45lLq42j8_WEzjM3AKoKx8McSYyDT1h8   # hoja del catálogo Activa
# HARDWARE_SPREADSHEET_ID=1MAfnl1TPwKD-9C56P-_BBl6JKcicHVplEXxZlpUHcP8
# USD_UYU_FALLBACK=40        # TC usado solo si el BCU se cae y no hay cache
# MACHINERY_PERCENT=7
# WASTE_PERCENT=17.5
# LABOR_PERCENT=40
# CUTS_PER_LABOR_HOUR=8
# LABOR_DAY_HOURS=8
# LABOR_DAY_PRICE_UYU=2500
# CUTS_PERCENT=20
# CUTS_BASE_MAX=50
# PROFIT_PERCENT=60
# PARTIAL_BOARD_FULL_THRESHOLD=95
# PARTIAL_BOARD_AREA_CONTINGENCY_PERCENT=7.5
# STATE_SURCHARGE_PERCENT=0
# DEFAULT_BID_PAYMENT_DAYS=60
# DEFAULT_BID_DESTINATION=Montevideo
# MONTEVIDEO_FLETE_UYU=900
# SHIPPING_UNLOAD_EMPLOYEES=2
# SHIPPING_UNLOAD_HOURS=3
# SHIPPING_UNLOAD_DAY_PRICE_UYU=2500
# BARRACA_PARANA_MARKUP=30

# ── Solo desarrollo local ────────────────────────────────────────────────────
# Excel maestro de molduras (solo en la máquina del dueño). Si no se setea, la
# app usa el CSV commiteado en carpinteria/data/ (que funciona en Railway).
# Para actualizar precios: editar el Excel y correr
#   uv run python scripts/flatten_price_sheets.py   (regenera los CSV)
# MOLDURAS_PRICE_FILE=C:\ruta\al\Listado de precios Molduras.xlsx
# PRICES_CACHE_FILE=         # ubicación de la copia local de Activa (default .cache/)
# PROJECT_ROOT=              # raíz del repo para el subproceso Python (Docker ya pone /app)
# PYTHON_CMD=                # comando Python a usar si no hay .venv
