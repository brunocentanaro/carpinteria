OPENAI_API_KEY=sk-your-key-here
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# Credenciales de Google: una de las dos.
# - Local: GOOGLE_SERVICE_ACCOUNT_FILE apunta al JSON.
# - Producción (Railway / Docker): GOOGLE_SERVICE_ACCOUNT_JSON con el JSON en
#   una línea (escapar saltos en private_key como `\n` literales). Si las dos
#   están seteadas, gana JSON.
GOOGLE_SERVICE_ACCOUNT_FILE=secrets/google/google-service.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

MARGIN_PERCENT=30
MONGO_URL=mongodb+srv://USER:PASS@HOST/?appName=carpinteria
MONGO_DB=carpinteria
AUTH_SESSION_SECRET=change-this-long-random-secret
CASA_AUTH_USER=casa
CASA_AUTH_PASSWORD=casa2026
PIRONE_AUTH_USER=pirone
PIRONE_AUTH_PASSWORD=pirone2026
RESET_EMAIL_TO=lacasadelcarpinterosa@gmail.com
